{
  "name": "google-next-scraper",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "Polite scraper for Google Cloud Next session library",
  "scripts": {
    "scrape": "node scrape_google_next.mjs",
    "refresh:verify": "node scripts/refresh_sanity.mjs",
    "build:insights": "node scripts/generate_insights.mjs",
    "build:changelog": "node scripts/generate_changelog.mjs",
    "update:parties": "node scripts/fetch_conference_parties.mjs",
    "analytics:init": "/root/.openclaw/workspace/.venv/bin/python scripts/snapshot_duckdb.py init",
    "analytics:top-fillers": "/root/.openclaw/workspace/.venv/bin/python scripts/snapshot_duckdb.py top-fillers",
    "analytics:flappy": "/root/.openclaw/workspace/.venv/bin/python scripts/snapshot_duckdb.py flappy",
    "test": "node --test tests/*.test.mjs",
    "test:gem-scheduler": "node --test tests/gem-scheduler-prompt.test.mjs tests/gem-scheduler-fixtures.test.mjs tests/gem-scheduler-evaluator.test.mjs",
    "gem:eval": "node scripts/evaluate_gem_scheduler_output.mjs",
    "merge": "node merge_buckets.mjs",
    "test:runbook": "node --test tests/runbook-smoke.test.mjs tests/refresh-process.test.mjs tests/website.test.mjs tests/company-identity.test.mjs tests/parser.test.mjs",
    "test:fixtures": "node --test tests/parser.test.mjs tests/website.test.mjs"
  }
}
